{
  "name": "miao-wechat-mini",
  "version": "1.0.0",
  "private": true,
  "description": "Miao WeChat Mini Program - Taro Version",
  "template": "react",
  "scripts": {
    "dev:weapp": "set NODE_OPTIONS=--openssl-legacy-provider && taro build --type weapp --watch",
    "dev:h5": "set NODE_OPTIONS=--openssl-legacy-provider && taro build --type h5 --watch",
    "build:weapp": "set NODE_OPTIONS=--openssl-legacy-provider && taro build --type weapp",
    "build:h5": "set NODE_OPTIONS=--openssl-legacy-provider && taro build --type h5",
    "lint": "eslint --ext .js,.jsx,.ts,.tsx src",
    "format": "prettier --write \"src/**/*.{js,jsx,ts,tsx}\""
  },
  "browserslist": [
    "last 3 versions",
    "Android >= 4.4",
    "ios >= 9"
  ],
  "dependencies": {
    "@tarojs/components": "^3.6.29",
    "@tarojs/mini-runner": "^3.6.37",
    "@tarojs/plugin-framework-react": "^3.6.29",
    "@tarojs/plugin-platform-h5": "^3.6.40",
    "@tarojs/plugin-platform-weapp": "^3.6.40",
    "@tarojs/react": "^3.6.29",
    "@tarojs/runtime": "^3.6.29",
    "@tarojs/taro": "^3.6.29",
    "@tarojs/webpack5-runner": "^3.6.29",
    "lucide-react": "^0.546.0",
    "qrcode.react": "^4.2.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@babel/core": "^7.24.0",
    "@babel/preset-env": "^7.29.2",
    "@babel/preset-react": "^7.28.5",
    "@babel/preset-typescript": "^7.28.5",
    "@tarojs/cli": "^3.6.29",
    "@tarojs/webpack-runner": "^3.6.37",
    "@types/react": "^18.2.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "babel-preset-taro": "^3.6.29",
    "eslint": "^8.0.0",
    "eslint-config-taro": "^3.6.29",
    "eslint-plugin-react": "^7.0.0",
    "prettier": "^3.0.0",
    "typescript": "^5.0.0",
    "webpack": "^4.47.0"
  }
}
